{
  "name": "discovery",
  "private": true,
  "type": "module",
  "description": "OpenRouter-backed LLM model registry with manual overrides",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "yarn build && yarn start",
    "sync": "yarn build && node dist/cli/sync.js",
    "test": "tsc -p tsconfig.json && NODE_NO_WARNINGS=1 node --test test/*.test.mjs",
    "admin": "yarn build && node dist/cli/admin.js",
    "dev:mem": "yarn build && node dist/dev/mem.js"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "pg-mem": "^3.0.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
